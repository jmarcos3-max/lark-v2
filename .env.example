# Copy to .env.local and fill in real values (never commit .env.local):
#   cp .env.example .env.local
#
# Get secrets from the project owner or your team's password manager.

# --- Base44 (optional for transform; needed for cloud audio upload) ---
# From https://Base44.com → your app → settings / GitHub integration
VITE_BASE44_APP_ID=
VITE_BASE44_APP_BASE_URL=

# --- Audiotool Nexus (required for login + transform → Studio) ---
# Create an app at https://developer.audiotool.com/applications
# Redirect URI must match exactly (trailing slash required):
VITE_AUDIOTOOL_CLIENT_ID=
# Local dev redirect (optional). Production/Pages uses the live site URL automatically.
# VITE_AUDIOTOOL_REDIRECT_URL=http://127.0.0.1:5173/

# --- ElevenLabs (optional — Wow Pass polish layers only) ---
# Dev server proxies via vite.config.js when this is set:
ELEVENLABS_API_KEY=
# Or use VITE_ELEVENLABS_API_KEY= for client-side (not recommended for production)
